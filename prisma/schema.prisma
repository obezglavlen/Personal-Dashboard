generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookmarks    Bookmark[]
  notes        Note[]
  tasks        Task[]
  settings     UserSettings?
  subscriptions Subscription[]
  taxConfigs   TaxConfig[]
  taxRecords   TaxRecord[]
  incomes      Income[]
  expenses     Expense[]
  budgets      Budget[]
  financialAccounts FinancialAccount[]
  goals             Goal[]
  netWorthSnapshots NetWorthSnapshot[]
  recurringTransactions RecurringTransaction[]
  tags              Tag[]
  calendarEvents    CalendarEvent[]
}

// Per-user tag catalog: the shared set of tags used for autocomplete across all
// tag-bearing modals (expenses, budgets, subscriptions, recurring, notes). Tags
// stay stored denormalized as `String[]` on each record; this table is the
// union kept in sync on every save, so a tag used anywhere is suggested
// everywhere.
model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  url         String
  title       String
  description String?
  category    String   @default("general")
  favicon     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tags])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  theme           String  @default("system")
  currency        String  @default("USD")
  dashboardLayout Json?
  // Telegram daily-digest notifications. Sending is "on" when telegramChatId is
  // set; the per-section flags choose what the digest includes.
  telegramChatId  String?
  notifyRenewals  Boolean @default(true)
  notifyBudgets   Boolean @default(true)
  notifyTasks     Boolean @default(true)
  // Monthly AI spending-insight message (separate from the daily digest).
  notifyInsights  Boolean @default(true)
  // Calendar events with a reminder set are surfaced in the daily digest once
  // their "remind before" lead time is reached (see CalendarEvent.reminderMinutes).
  notifyEvents    Boolean @default(true)
  // Last time a monthly insight was sent — makes the monthly job idempotent so a
  // timed-out/re-run invocation never double-sends or drops users.
  lastInsightAt   DateTime?
  // Percent-of-cap at which a budget is surfaced in the digest (e.g. 80 = warn
  // from 80% spent).
  budgetAlertThreshold Int @default(80)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  name      String
  price     Decimal  @db.Decimal(10, 2)
  period    String
  startDate DateTime @default(now())
  // Free-form tags (shared with expenses/budgets/recurring via the Tag catalog).
  tags      String[]
  currency  String   @default("USD")
  // When true, renewals are auto-posted as Expense rows. `lastPostedAt` records
  // the most recent renewal date already posted, so posting stays idempotent.
  autoExpense  Boolean   @default(false)
  lastPostedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([period])
}

model TaxConfig {
  id           String     @id @default(cuid())
  userId       String
  name         String
  rate         Decimal    @default(0) @db.Decimal(5, 2)
  staticAmount Decimal?   @db.Decimal(10, 2)
  currency     String     @default("USD")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  records      TaxRecord[]
  incomes      Income[]

  @@unique([userId, name])
  @@index([userId])
}

model TaxRecord {
  id          String     @id @default(cuid())
  userId      String
  taxConfigId String?
  date        DateTime
  amount      Decimal?   @db.Decimal(10, 2)
  currency    String     @default("USD")
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxConfig   TaxConfig? @relation(fields: [taxConfigId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
}

// Income entries, split out of TaxRecord (which now only holds tax expenses).
// An income row may reference a TaxConfig — this scopes it to a tax type and
// lets the tax-record form pre-fill a rate-based amount off it.
model Income {
  id          String     @id @default(cuid())
  userId      String
  taxConfigId String?
  date        DateTime
  amount      Decimal?   @db.Decimal(10, 2)
  currency    String     @default("USD")
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxConfig   TaxConfig? @relation(fields: [taxConfigId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("USD")
  date      DateTime
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("USD")
  period    String   @default("monthly")
  // Expenses whose tags intersect these count toward the budget. Empty = all expenses.
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FinancialAccount {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   @default("cash")
  // Balance may be negative for liabilities (loans, credit cards).
  balance   Decimal  @db.Decimal(14, 2)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  target    Decimal  @db.Decimal(14, 2)
  current   Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A recurring income or expense. Generalizes subscription auto-posting: when
// `autoPost` is on, each due charge is posted (expense → Expense, income →
// Income). `lastPostedAt` keeps posting idempotent; `endDate` optionally stops
// the recurrence.
model RecurringTransaction {
  id           String    @id @default(cuid())
  userId       String
  name         String
  amount       Decimal   @db.Decimal(10, 2)
  type         String    // "income" | "expense"
  period       String    // "monthly" | "annual"
  startDate    DateTime  @default(now())
  endDate      DateTime?
  currency     String    @default("USD")
  tags         String[]
  autoPost     Boolean   @default(false)
  lastPostedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// A daily snapshot of a user's net worth, stored as balances grouped by
// currency (`byCurrency` = { USD: 1200.50, EUR: -300 }). Display conversion —
// and point-in-time FX via ExchangeRateSnapshot — happens at read time.
model NetWorthSnapshot {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  byCurrency Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// A daily snapshot of exchange rates so historical figures convert at the rate
// that was true then, not today's live rate. Global (not per-user). `rates` is
// the frankfurter shape: rates[X] = units of X per 1 `base`. One row per
// (base, day); `date` is the UTC day the rates are for.
model ExchangeRateSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  base      String
  rates     Json
  source    String   @default("frankfurter")
  createdAt DateTime @default(now())

  @@unique([base, date])
  @@index([date])
}

// A personal-calendar event. A row is one of three things:
//   1. a single event         — `recurrence = "none"`, `seriesId = null`
//   2. a recurring master      — `recurrence != "none"`, `seriesId = null`
//   3. a single-occurrence override of a master (Google-style "edit this
//      event"/"delete this event") — `seriesId` set, `overrideDate` = the
//      original occurrence it replaces. `canceled = true` makes it a tombstone
//      that hides that one occurrence; otherwise it supplies replacement fields.
// Occurrences of a master are expanded on read (see lib/calendar) rather than
// stored, so an infinite series costs one row. `reminderMinutes` (minutes
// before `startAt`) drives the daily-digest heads-up when a reminder is set.
model CalendarEvent {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String?
  location        String?
  startAt         DateTime
  endAt           DateTime?
  allDay          Boolean   @default(false)
  recurrence      String    @default("none") // none | daily | weekly | monthly | yearly
  recurrenceEnd   DateTime?
  reminderMinutes Int?
  tags            String[]  @default([])
  seriesId        String?
  overrideDate    DateTime?
  canceled        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startAt])
  @@index([seriesId])
}

{
	"buildCommand": "rm -rf generated .next && npx prisma generate && npx prisma migrate deploy && pnpm build",
	"installCommand": "pnpm install",
	"crons": [
		{
			"path": "/api/cron/capture-rates",
			"schedule": "0 5 * * *"
		},
		{
			"path": "/api/cron/post-renewals",
			"schedule": "0 6 * * *"
		},
		{
			"path": "/api/cron/notify",
			"schedule": "0 7 * * *"
		},
		{
			"path": "/api/cron/monthly-insight",
			"schedule": "0 9 1 * *"
		}
	]
}

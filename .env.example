# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/home_dashboard?schema=public"
# Max connections in the pg pool. Defaults to 3 (safe for Prisma Postgres's
# low direct-connection limit). Raise on a bigger DB — e.g. 10 to match pg's
# old default, or higher. There is no true "unlimited" in the pg pool.
# DATABASE_POOL_MAX="3"

# NextAuth
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# AI assistant (OpenRouter). Get a key at https://openrouter.ai/keys.
# CHAT_MODEL must support tool/function calling — verify on the model's
# OpenRouter page. Defaults to deepseek/deepseek-chat if unset.
OPENROUTER_API_KEY="sk-or-..."
CHAT_MODEL="deepseek/deepseek-chat"
# Chain-of-thought depth for reasoning models: xhigh|high|medium|low|minimal|none.
# "minimal" = fastest answers; "none" = reasoning off. Defaults to minimal.
REASONING_EFFORT="minimal"

# Cron: shared secret guarding /api/cron/post-renewals (subscription auto-post).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# On Vercel, set this in project env; Vercel cron auto-sends it as a Bearer token.
CRON_SECRET="your-cron-secret-here"

# Telegram daily-digest notifications (renewals due, budgets over cap, overdue
# tasks). Create a bot via @BotFather and paste its token here. Each user links
# their numeric chat id in Settings → Notifications (get it from @userinfobot).
# The digest is sent by the /api/cron/notify cron, guarded by CRON_SECRET above.
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
